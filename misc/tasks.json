{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "atcoder-tools test",
            "type": "shell",
            "command": "atcoder-tools",
            "args": [
                "test",
                "--dir",
                "${fileDirname}",
                "--config",
                "${userHome}/ProconLibrary/.atcodertools.toml"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "copy generated code",
            "type": "shell",
            "command": "bundle-copy",
            "args": [
                "${fileDirname}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "build for debug",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-g",
                "-fsanitize=undefined,address",
                "-I",
                "${userHome}/cpp",
                "--std=c++23",
                "-o",
                "${fileDirname}/main",
                "${fileDirname}/main.cpp"
            ],
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
